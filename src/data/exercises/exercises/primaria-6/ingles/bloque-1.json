        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "Which is the past of \"write\"?",
        "opciones": [
          "Wrote",
          "Writed",
          "Writing",
          "Writes"
        ],
        "respuestaCorrecta": "Wrote",
        "explicacion": "Write → wrote (irregular). I wrote a letter = escribí una carta."
      },
      {
        "id": "p6en-b1-10",
        "tema": "Pasado",
        "tipo": "true_false",
        "nivel": "v1",
        "pregunta": "\"Last week\" means la semana pasada",
        "opciones": [
          "Verdadero",
          "Falso"
        ],
        "respuestaCorrecta": "true",
        "explicacion": "Last = pasado/a. Last week = la semana pasada. Last year = el año pasado."
      }
