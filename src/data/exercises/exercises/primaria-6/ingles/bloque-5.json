  "bloque": 5,
  "nombre": "Review and goodbye",
  "meses": "Abr-Jun",
  "temas": [
    "Grammar review",
    "Farewell"
  ],
  "totalEjercicios": 10,
  "ejercicios": {
    "v1": [
      {
        "id": "p6en-b5-01",
        "tema": "Repaso",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "Which is correct: \"She go\" or \"She goes\"?",
        "opciones": [
          "She goes",
          "She go",
          "She going",
          "She goed"
        ],
        "respuestaCorrecta": "She goes",
        "explicacion": "3a persona singular en presente simple: he/she/it + verbo + s."
      },
      {
        "id": "p6en-b5-02",
        "tema": "Repaso",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "\"There are five books\" means:",
        "opciones": [
          "Hay cinco libros",
          "Hay un libro",
          "No hay libros",
          "Hubo cinco libros"
        ],
        "respuestaCorrecta": "Hay cinco libros",
        "explicacion": "There are = hay (plural). There is = hay (singular)."
      },
      {
        "id": "p6en-b5-03",
        "tema": "Repaso",
        "tipo": "true_false",
        "nivel": "v1",
        "pregunta": "\"Can\" is used to express ability",
        "opciones": [
          "Verdadero",
          "Falso"
        ],
        "respuestaCorrecta": "true",
        "explicacion": "I can swim = puedo/sé nadar. Can expresa habilidad o capacidad."
      },
      {
        "id": "p6en-b5-04",
        "tema": "Despedida",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "\"See you in secondary school!\" means:",
        "opciones": [
          "¡Nos vemos en la secundaria!",
          "¡Adiós para siempre!",
          "¡Hola!",
          "¡Buenos días!"
        ],
        "respuestaCorrecta": "¡Nos vemos en la secundaria!",
        "explicacion": "See you = nos vemos. Secondary school = escuela secundaria."
      },
      {
        "id": "p6en-b5-05",
        "tema": "Repaso",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "Complete: \"I ___ to the park yesterday\"",
        "opciones": [
          "went",
          "go",
          "going",
          "goes"
        ],
        "respuestaCorrecta": "went",
        "explicacion": "Go → went (pasado). Yesterday requiere pasado simple."
      },
      {
        "id": "p6en-b5-06",
        "tema": "Repaso",
        "tipo": "true_false",
        "nivel": "v1",
        "pregunta": "\"Must\" is stronger than \"should\"",
        "opciones": [
          "Verdadero",
          "Falso"
        ],
        "respuestaCorrecta": "true",
        "explicacion": "Must = debes (obligación). Should = deberías (consejo). Must es más fuerte."
      },
      {
        "id": "p6en-b5-07",
        "tema": "Repaso",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "\"Would you like some water?\" means:",
        "opciones": [
          "¿Te gustaría un poco de agua?",
          "¿Tienes agua?",
          "¿Dónde está el agua?",
          "No quiero agua"
        ],
        "respuestaCorrecta": "¿Te gustaría un poco de agua?",
        "explicacion": "Would you like = ¿Te gustaría? Es una forma educada de ofrecer."
      },
      {
        "id": "p6en-b5-08",
        "tema": "Despedida",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "\"Good luck in secondary!\" means:",
        "opciones": [
          "¡Buena suerte en la secundaria!",
          "¡Mala suerte!",
          "¡Adiós escuela!",
          "¡No quiero ir!"
        ],
        "respuestaCorrecta": "¡Buena suerte en la secundaria!",
        "explicacion": "Good luck = buena suerte. Un deseo positivo para el futuro."
      },
      {
        "id": "p6en-b5-09",
        "tema": "Repaso",
        "tipo": "multiple_choice",
        "nivel": "v1",
        "pregunta": "Which sentence is in future tense?",
        "opciones": [
          "I will study English",
          "I study English",
          "I studied English",
          "I am studying English"
        ],
        "respuestaCorrecta": "I will study English",
        "explicacion": "Will + verbo = futuro. I will study = estudiaré."
      },
      {
        "id": "p6en-b5-10",
        "tema": "Despedida",
        "tipo": "true_false",
        "nivel": "v1",
        "pregunta": "\"I learned a lot this year\" is in past tense",
        "opciones": [
          "Verdadero",
          "Falso"
        ],
        "respuestaCorrecta": "true",
        "explicacion": "Learned = aprendí (pasado). This year = este año."
      }
    ],
