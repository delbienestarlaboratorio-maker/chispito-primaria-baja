        "pregunta": "\"Ship\" means:",
        "opciones": [
          "Barco",
          "Submarino",
          "Helicóptero",
          "Bicicleta"
        ],
        "respuestaCorrecta": "Barco",
        "explicacion": "Ship = barco grande. Boat = bote o barco pequeño."
