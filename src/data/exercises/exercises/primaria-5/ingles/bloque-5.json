        "pregunta": "\"Airplane\" means:",
        "opciones": [
          "Avión",
          "Barco",
          "Tren",
          "Autobús"
        ],
        "respuestaCorrecta": "Avión",
        "explicacion": "Airplane = avión. Plane es la forma corta."
